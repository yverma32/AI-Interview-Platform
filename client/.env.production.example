# Copy to .env.production and fill, OR set these in the Vercel dashboard
# (Settings → Environment Variables). Vercel reads these at build time.

# Public URL of the API (Railway public domain, no trailing slash, no /api)
VITE_API_URL=https://your-app.up.railway.app

# Optional analytics (leave blank to disable PostHog)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
